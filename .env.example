# ── App ──────────────────────────────────────
APP_NAME="FastAPI Project"
APP_VERSION="1.0.0"
DEBUG=True
API_PREFIX="/api/v1"

# ── Server ───────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── Database ─────────────────────────────────
DATABASE_URL=
# SQLite (for local dev without Postgres):
# DATABASE_URL=sqlite+aiosqlite:///./fastapi.db

# ── Security ─────────────────────────────────
SECRET_KEY=
ALGORITHM=
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Default Admin ────────────────────────────
DEFAULT_ADMIN_EMAIL=
DEFAULT_ADMIN_USERNAME=
DEFAULT_ADMIN_PASSWORD=
DEFAULT_ADMIN_FULL_NAME=

# ── CORS ─────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]
FRONTEND_URL="http://localhost:3000"


# ── Email (optional) ─────────────────────────
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=

# GG
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# ── MODEL API SPEECH TO TEXT ──────────────────────────────────
DEEPGRAM_API_KEY=
DEEPGRAM_MODEL="general"

# ── API MODEL EXTRACT CV ─────────────────────────────────
GEMINI_API_KEY=xxxxx
MODEL_NAME=models/gemini-2.5-flash

# ── TTS / ElevenLabs ─────────────────────────────────────
ELEVEN_API_KEY=
# Rachel (XrExE9yKIg1WjnnlVkGX) - tốt nhất cho tiếng Việt
DEFAULT_VOICE_ID=XrExE9yKIg1WjnnlVkGX
# eleven_multilingual_v2 - chất lượng cao nhất cho Việt + Anh xen lẫn
DEFAULT_MODEL=eleven_multilingual_v2
